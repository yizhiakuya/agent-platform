# ============================================================
# Agent Platform — environment variables
# Copy this file to `.env` and fill in real values before
# running `docker compose up`.
# ============================================================

# --- LLM provider (used by agent-service) ---
# Set ONE of the following based on LLM_PROVIDER.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-xxx-replace-me
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Default model for chat (Claude Sonnet 4.6 recommended)
LLM_CHAT_MODEL=claude-sonnet-4-6

# --- Embedding provider (used by memory recall + fact storage) ---
# When ANTHROPIC_BASE_URL points at an anthropic-only relay (sub2api etc),
# you MUST set these — anthropic has no OpenAI /v1/embeddings endpoint, so
# memory recall will silently 404 every request and cross-session memory
# stops working.
#
# Default config below uses Jina (jina-embeddings-v3, 1024 dim, 1M tokens
# free tier). Get a key at https://jina.ai/embeddings/. Schema is shipped
# at 1024 dim to match.
#
# Alternative providers:
#   - OpenAI text-embedding-3-small (1536 dim — needs schema migration back)
#       MEMORY_EMBEDDING_BASE_URL=https://api.openai.com
#       MEMORY_EMBEDDING_MODEL=text-embedding-3-small
#       MEMORY_EMBEDDING_DIM=1536
#       MEMORY_EMBEDDING_TASK=  (leave blank — OpenAI rejects task field)
#   - Self-hosted TEI / ollama: any OpenAI-compatible /v1/embeddings; set
#     MODEL/DIM/TASK accordingly.
MEMORY_EMBEDDING_BASE_URL=https://api.jina.ai
MEMORY_EMBEDDING_API_KEY=jina_replace-me
# Jina v3 requires task; OpenAI rejects it. retrieval.passage works for both
# store+recall as a one-size-fits-all (asymmetric query/passage is cleaner
# but adds complexity).
MEMORY_EMBEDDING_TASK=retrieval.passage
MEMORY_EMBEDDING_MODEL=jina-embeddings-v3
MEMORY_EMBEDDING_DIM=1024

# --- JWT / Auth ---
# HS256 secret. Generate with: openssl rand -base64 64
JWT_SECRET=replace-with-64-bytes-of-random-base64-and-keep-it-secret
JWT_USER_TOKEN_TTL_HOURS=24
JWT_DEVICE_TOKEN_TTL_DAYS=365

# --- Postgres ---
POSTGRES_PORT=5432
POSTGRES_USER=agent
POSTGRES_PASSWORD=changeme-in-prod
# Per-service schema passwords (used by infra/postgres/init/01-init.sh)
AUTH_DB_PASSWORD=auth_changeme
CHAT_DB_PASSWORD=chat_changeme
HUB_DB_PASSWORD=hub_changeme

# --- Nacos ---
NACOS_PORT=8848
NACOS_GRPC_PORT=9848
# Set to "true" only after you have bootstrapped an admin account via the
# Nacos UI. On a fresh container Nacos 2.2.1+ requires you to create the
# first account manually. For local dev keep this off.
NACOS_AUTH_ENABLE=false
# Nacos 2.2.1+ requires explicit auth identity. Generate:
#   openssl rand -base64 32  (for NACOS_AUTH_TOKEN, must be >=32 bytes)
#   openssl rand -hex 16     (for NACOS_AUTH_IDENTITY_VALUE)
NACOS_AUTH_TOKEN=replace-with-base64-32-bytes-min-for-token-secret-key-padded-please
NACOS_AUTH_IDENTITY_KEY=serverIdentity
NACOS_AUTH_IDENTITY_VALUE=replace-with-random-hex
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos

# --- Server / public URL ---
# The public-facing host of the gateway (used for QR codes, redirects, CORS).
SERVER_PUBLIC_URL=http://localhost:8080
WEB_PUBLIC_URL=http://localhost:3000

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Deployment-only variant for services that do not need curl inside the
# container. It avoids flaky Alpine package-index fetches during hotfix builds.
FROM maven:3.9.11-eclipse-temurin-21-alpine AS build
ARG SERVICE
WORKDIR /app

COPY .mvn ./.mvn
COPY pom.xml ./
COPY common ./common
COPY auth-service/pom.xml          ./auth-service/pom.xml
COPY gateway/pom.xml                ./gateway/pom.xml
COPY device-hub-service/pom.xml     ./device-hub-service/pom.xml
COPY agent-service/pom.xml          ./agent-service/pom.xml
COPY chat-service/pom.xml           ./chat-service/pom.xml
RUN mvn -B -pl ${SERVICE} -am dependency:resolve -DskipTests || true

COPY ${SERVICE} ./${SERVICE}
RUN mvn -B -pl ${SERVICE} -am package -DskipTests

FROM eclipse-temurin:21-jre-alpine
ARG SERVICE
WORKDIR /app
COPY --from=build /app/${SERVICE}/target/*.jar /app/app.jar
ENTRYPOINT ["java", "-XX:+UseG1GC", "-XX:MaxRAMPercentage=75", "-jar", "/app/app.jar"]

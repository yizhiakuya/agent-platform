# Maven Wrapper — keep LF on bash launcher, CRLF on Windows batch
mvnw text eol=lf
mvnw.cmd text eol=crlf
*.sh text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf

# Source files normalized to LF (cross-platform)
*.java text eol=lf
*.kt text eol=lf
*.kts text eol=lf
*.gradle text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.json text eol=lf
*.md text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.sql text eol=lf
Dockerfile text eol=lf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
*.zip binary
*.tar.gz binary
*.apk binary
